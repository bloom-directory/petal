package bloom:vfs@0.1.0;

interface readwrite {
  enum entry-kind {
    dir,
    file,
    symlink,
  }

  record entry {
    name: string,
    kind: entry-kind,
    mode: u32,
    size: option<u64>,
    link-target: option<string>,
  }

  lookup: func(path: string) -> result<entry, string>;
  %list: func(path: string) -> result<list<entry>, string>;
  read: func(path: string) -> result<list<u8>, string>;
  write: func(path: string, body: list<u8>) -> result<_, string>;
}
